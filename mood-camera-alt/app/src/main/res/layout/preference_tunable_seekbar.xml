<?xml version="1.0" encoding="utf-8"?>
<!-- Custom layout for tunable seekbars - wider without icon space -->
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:gravity="top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?android:listPreferredItemHeight"
        android:paddingEnd="?android:scrollbarSize"
        android:paddingStart="16dp"
        android:orientation="vertical">
    
    <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="@dimen/camera_settings_entry_margin"
            android:layout_marginEnd="@dimen/camera_settings_entry_margin">
        
        <TextView
                android:textSize="@dimen/camera_settings_preference_font_size"
                android:ellipsize="marquee"
                android:id="@android:id/title"
                android:fadingEdge="horizontal"
                tools:text="SeekBar Title"
                android:gravity="start|center_vertical"
                android:textColor="?android:textColorPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        
        <TextView
                android:textAppearance="?android:textAppearanceSmall"
                android:textColor="?android:textColorSecondary"
                android:id="@android:id/summary"
                android:layout_width="wrap_content"
                tools:text="SeekBar description"
                android:layout_height="wrap_content"
                android:layout_below="@android:id/title"
                android:layout_alignStart="@android:id/title"/>

        <SeekBar
                android:id="@+id/seekbar"
                android:paddingTop="@dimen/preference_seekbar_padding"
                android:paddingBottom="@dimen/preference_seekbar_padding"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@android:id/summary"
                android:layout_toStartOf="@id/seekbar_value"
                android:paddingStart="10dp"
                android:paddingEnd="8dp"/>
        
        <TextView 
                android:layout_width="@dimen/preference_seekbar_value_text_width"
                android:layout_height="wrap_content"
                android:textAppearance="?android:textAppearanceSmall"
                android:textColor="?android:textColorSecondary"
                android:id="@+id/seekbar_value"
                android:paddingStart="@dimen/preference_seekbar_value_padding"
                android:paddingEnd="@dimen/preference_seekbar_value_padding"
                android:layout_alignParentEnd="true"
                android:layout_alignBottom="@id/seekbar"
                android:layout_alignTop="@id/seekbar"
                android:gravity="center"
                tools:text="10000"/>
    </RelativeLayout>
</LinearLayout>



